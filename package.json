{
  "name": "github-style-heading-links",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "description": "Obsidian plugin for GitHub-style heading fragment links",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "check": "tsc --noEmit",
    "sync": "bash scripts/sync-vault.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.6",
    "@types/node": "^24.0.0",
    "@vitest/ui": "^4.1.8",
    "esbuild": "^0.25.5",
    "happy-dom": "^20.9.0",
    "obsidian": "^1.8.10",
    "typescript": "5.8.3",
    "vitest": "^4.1.8"
  }
}
